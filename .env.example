# OpenAI-compatible API (for generate-post script)
# Copy to .env and fill in values.

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
# One model for generation; or comma-separated list — build picks one at random as “Author”.
OPENAI_MODEL=gpt-4o
# OPENAI_MODEL=gpt-4o,claude-3-5-sonnet-20241022,deepseek-chat

# Shown as “Author” on each post (paper-style byline). Optional.
# OPENAI_MODEL_INTRO=Generated by the above model for shitposts.org. Not peer-reviewed.
